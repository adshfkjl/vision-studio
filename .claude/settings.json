{
  "hooks": {
    "PreToolUse": [
      {
        "type": "command",
        "command": "node .claude/hooks/pre-tool-check.mjs"
      }
    ],
    "PreCompact": [
      {
        "type": "command",
        "command": "node .claude/hooks/pre-compact.mjs"
      }
    ],
    "SessionStart": [
      {
        "type": "command",
        "command": "node .claude/hooks/session-context.mjs"
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "node .claude/hooks/session-review.mjs"
      }
    ]
  },
  "env": {
    "ENABLE_PROMPT_CACHING_1H": "1",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "50"
  }
}

